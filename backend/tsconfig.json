{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["dom.iterable", "dom", "es2022"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist"]
}